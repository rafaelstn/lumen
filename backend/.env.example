# Banco de dados (usado a partir dos módulos futuros)
DATABASE_URL=postgresql+asyncpg://fiscal_user:fiscal_pass@postgres:5432/fiscal_db

# CORS — origens permitidas (separadas por vírgula)
CORS_ORIGINS=http://localhost:3000

# Consulta CND — portal da Receita Federal
CND_PORTAL_URL=https://solucoes.receita.fazenda.gov.br/Servicos/certidaointernet/PJ/Emitir
CND_DELAY_MIN=3.0
CND_DELAY_MAX=8.0
CND_MAX_RETRIES=3

# Solver de captcha (2Captcha / Anti-Captcha) — NUNCA commitar a chave real
CAPTCHA_PROVIDER=2captcha
CAPTCHA_API_KEY=

# Diretório de armazenamento temporário de jobs (uploads, logs, PDFs)
JOBS_DIR=/app/_jobs
