# Banco de dados (usado a partir dos módulos futuros)
DATABASE_URL=postgresql+asyncpg://fiscal_user:fiscal_pass@postgres:5432/fiscal_db

# CORS — origens permitidas (separadas por vírgula)
CORS_ORIGINS=http://localhost:3000

# Lookup de CNPJ por nome / enriquecimento (CNPJá) — NUNCA commitar a chave real
CNPJ_LOOKUP_PROVIDER=cnpja
CNPJ_LOOKUP_BASE_URL=https://api.cnpja.com
CNPJ_LOOKUP_API_KEY=
CNPJ_LOOKUP_LIMITE_PADRAO=20

# Consulta de CND (regularidade fiscal) via Infosimples — NUNCA commitar o token real
CND_PROVIDER=infosimples
INFOSIMPLES_BASE_URL=https://api.infosimples.com/api/v2/consultas
INFOSIMPLES_TOKEN=
INFOSIMPLES_TIMEOUT=120
CND_LIMITE_PADRAO=20
CND_CONCORRENCIA=4
